# Credentials and secrets — never commit these
*.env
credentials*
*password*
*secret*
*.key
*.pem
*.pfx
*.p12
id_rsa
id_rsa.pub

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Large binary files — store externally if needed
*.iso
*.ova
*.vmdk
*.vhd
*.qcow2

# Screenshots with sensitive data — review before committing
# Remove this line when you've verified screenshots are clean
# SCREENSHOTS/

# Temp files
*.tmp
*.log
*.bak
